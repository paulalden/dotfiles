{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git push -f)",
      "Bash(find *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git stash list*)",
      "Bash(brew install*)",
      "Bash(brew update*)",
      "Bash(ruby *)",
      "Bash(gem install*)",
      "Bash(gem uninstall*)",
      "Bash(bundle install*)",
      "Bash(bundle update*)",
      "Bash(rails *)",
      "Bash(rake *)",
      "Bash(rspec *)",
      "Bash(rubocop *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(open *)",
      "Bash(yabai *)",
      "Bash(skhd *)",
      "Bash(brew services*)",
      "Bash(tmux *)",
      "Bash(nvim *)",
      "Bash(vim *)",
      "Bash(ls*)",
      "Bash(grep *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git status *)",
      "Bash(git status *)",
      "Bash(cd * && git show *)",
      "Bash(cd * && git log *)",
      "Bash(cd * && git diff *)",
      "Bash(cd * && git branch *)",
      "Bash(cd * && git status *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cd * && ls *)",
      "Bash(cat *)",
      "Bash(cd * && cat *)",
      "Bash(cd * && find *)",
      "Bash(cd * && grep *)",
      "Bash(git:*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset*)",
      "Bash(sudo *)",
      "Bash(rm -r*)",
      "Bash(rails destroy*)",
      "Bash(rails db:drop*)",
      "Bash(rails db:reset*)",
      "Bash(rake db:drop*)",
      "Bash(rake db:reset*)",
      "Bash(rake db:purge*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qE 'git (show|log|diff|branch|status|remote|describe)'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Git read operation\"}}'; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ombulabs-ai": {
      "source": {
        "source": "github",
        "repo": "ombulabs/claude-skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "skipAutoPermissionPrompt": true,
  "additionalDirectories": ["/Users/paul/Personal/repos/dotfiles"]
}