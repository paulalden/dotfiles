#!/usr/bin/env sh

# for this to work you must configure sudo such that
# it will be able to run the command without password
#
# see this wiki page for information:
#  - https://github.com/koekeishiya/yabai/wiki/Installing-yabai-(latest-release)#configure-scripting-addition

sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
yabai -m signal --add event=space_created action="sketchybar --reload"
yabai -m signal --add event=space_destroyed action="sketchybar --reload"

# Hostnames — run `scutil --get ComputerName` to check
HOSTNAME_16INCH="Pauls-Examtrack-MacBook-Pro"  # MacBook Pro 16" (notch)
HOSTNAME_13INCH="PaulM1"                 # MacBook Pro 13" (no notch)
CURRENT_HOST="$(scutil --get LocalHostName)"

EXTERNAL_TOP_PADDING=50  # external monitor
TOP_PADDING_16INCH=20    # MacBook Pro 16" (notch)
TOP_PADDING_13INCH=65    # MacBook Pro 13"

case "$CURRENT_HOST" in
  "$HOSTNAME_16INCH") BUILTIN_TOP_PADDING=$TOP_PADDING_16INCH ;;
  "$HOSTNAME_13INCH") BUILTIN_TOP_PADDING=$TOP_PADDING_13INCH ;;
  *)                  BUILTIN_TOP_PADDING=$EXTERNAL_TOP_PADDING ;;
esac

get_top_padding() {
  yabai -m query --displays 2>/dev/null | jq -r --argjson idx "$1" '.[] | select(.index == $idx) | .["is-built-in"]' | \
    grep -q true && echo $BUILTIN_TOP_PADDING || echo $EXTERNAL_TOP_PADDING
}

configure_padding() {
  yabai -m query --displays 2>/dev/null | jq -r '.[] | [.index, .["is-built-in"]] | @tsv' | \
  while IFS=$(printf '\t') read -r index builtin; do
    [ "$builtin" = "true" ] && top=$BUILTIN_TOP_PADDING || top=$EXTERNAL_TOP_PADDING
    yabai -m config --display "$index" top_padding "$top"
  done
}

yabai -m signal --add event=display_added   action="yabai -m query --displays | jq -r '.[] | [.index, .[\"is-built-in\"]] | @tsv' | while IFS=\$(printf '\t') read -r i b; do [ \"\$b\" = \"true\" ] && t=$BUILTIN_TOP_PADDING || t=$EXTERNAL_TOP_PADDING; yabai -m config --display \"\$i\" top_padding \"\$t\"; done"
yabai -m signal --add event=display_removed action="yabai -m query --displays | jq -r '.[] | [.index, .[\"is-built-in\"]] | @tsv' | while IFS=\$(printf '\t') read -r i b; do [ \"\$b\" = \"true\" ] && t=$BUILTIN_TOP_PADDING || t=$EXTERNAL_TOP_PADDING; yabai -m config --display \"\$i\" top_padding \"\$t\"; done"

# global settings
yabai -m config \
  mouse_follows_focus off \
  focus_follows_mouse off \
  window_origin_display default \
  window_placement second_child \
  window_zoom_persist on \
  window_shadow on \
  window_animation_duration 0.0 \
  window_opacity_duration 0.0 \
  active_window_opacity 1.0 \
  normal_window_opacity 0.90 \
  window_opacity off \
  insert_feedback_color 0xffd75f5f \
  split_ratio 0.50 \
  split_type auto \
  auto_balance off \
  top_padding $EXTERNAL_TOP_PADDING \
  bottom_padding 15 \
  left_padding 15 \
  right_padding 15 \
  window_gap 15 \
  layout bsp \
  mouse_modifier fn \
  mouse_action1 move \
  mouse_action2 resize \
  mouse_drop_action swap

configure_padding

# apps to not manage (ignore)
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Alfred Preferences$" manage=off
yabai -m rule --add title='Preferences$' manage=off layer=above

borders active_color=0xffcbb1c7 inactive_color=0xff2e3440 width=5.0 2>/dev/null 1>&2 &

echo "yabai configuration loaded.."